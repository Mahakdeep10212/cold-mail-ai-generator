# Server Configuration
PORT=5000
MONGODB_URI=mongodb://localhost:27017/cold-mail-generator

# JWT Secret
JWT_SECRET=supersecretjwtkeyfor-ai-cold-mail-generator-123456

# Nodemailer Configuration (Gmail SMTP)
# Set USE_MOCK_EMAIL=true to bypass sending actual emails and log OTPs to console
USE_MOCK_EMAIL=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Google Gemini AI API Configuration
GEMINI_API_KEY=your-gemini-api-key

# Groq AI API Configuration
GROQ_API_KEY=your-groq-api-key

# Resend Mailer Configuration (Alternative to SMTP)
# RESEND_API_KEY=re_your-resend-api-key
# RESEND_FROM_EMAIL=your-verified-name <no-reply@yourdomain.com>

# Brevo Mailer Configuration (HTTP API to bypass port blocks)
# BREVO_API_KEY=your-brevo-api-key
# BREVO_SENDER_EMAIL=your-verified-sender-email@gmail.com


